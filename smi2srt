def parse_style(smi):
    """
    SMI 파일의 <HEAD><STYLE> 안에 있는 P 태그 및 클래스 스타일 정보를 파싱합니다.
    반환: dict
      - 'P': 기본 P 스타일 (margin-left, font-size, color 등)
      - 'classes': .ClassName 스타일 (예: .KRCC)
      - 'ids': #ID 스타일 (예: #STDPrn, #LargePrn)
    """
    result = {'P': {}, 'classes': {}, 'ids': {}}

    # <STYLE ...> ... </STYLE> 구간 추출 (대소문자 무시)
    style_match = re.search(r'<style[^>]*>(.*?)</style>', smi, re.I | re.DOTALL)
    if not style_match:
        return result

    style_block = style_match.group(1)
    # SMI는 CSS가 주석 안에 있음. 주석을 지우면 내용까지 사라지므로, 주석 안쪽만 추출
    comment_match = re.search(r'<!--(.*?)-->', style_block, re.DOTALL)
    if comment_match:
        style_block = comment_match.group(1)

    def parse_css_properties(inner):
        """중괄호 안 내용을 '속성:값' 쌍으로 파싱"""
        props = {}
        # 세미콜론으로 구분, 각 항목에서 key : value 추출
        for part in re.split(r'\s*;\s*', inner):
            part = part.strip()
            if ':' in part:
                key, _, value = part.partition(':')
                props[key.strip()] = value.strip()
        return props

    # P { ... }  (기본 단락 스타일)
    p_match = re.search(r'P\s*\{([^}]*)\}', style_block, re.I | re.DOTALL)
    if p_match:
        result['P'] = parse_css_properties(p_match.group(1))

    # .ClassName { ... }
    for m in re.finditer(r'\.(\w+)\s*\{([^}]*)\}', style_block, re.DOTALL):
        result['classes'][m.group(1).lower()] = parse_css_properties(m.group(2))

    # #ID { ... }
    for m in re.finditer(r'#(\w+)\s*\{([^}]*)\}', style_block, re.DOTALL):
        result['ids'][m.group(1)] = parse_css_properties(m.group(2))

    return result


